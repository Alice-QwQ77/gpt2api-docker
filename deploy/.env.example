KLEIN_IMAGE=ghcr.io/alice-qwq77/gpt2api:latest

KLEIN_ENV=prod

KLEIN_USER_WEB_PORT=17080
KLEIN_ADMIN_WEB_PORT=17088
KLEIN_OPENAI_PORT=17200

KLEIN_MYSQL_PORT=13306
KLEIN_MYSQL_ROOT_PASSWORD=change_this_root_password
KLEIN_MYSQL_DB=klein_ai
KLEIN_MYSQL_USER=klein
KLEIN_MYSQL_PASSWORD=change_this_mysql_password
KLEIN_DB_DSN=klein:change_this_mysql_password@tcp(mysql:3306)/klein_ai?charset=utf8mb4&parseTime=True&loc=Local

KLEIN_REDIS_PORT=16379
KLEIN_REDIS_ADDR=redis:6379
KLEIN_REDIS_PASSWORD=

KLEIN_JWT_SECRET=change_this_to_at_least_32_bytes_secret
KLEIN_JWT_REFRESH_SECRET=change_this_to_at_least_32_bytes_refresh
KLEIN_AES_KEY=0123456789abcdef0123456789abcdef

KLEIN_GPT_BASE_URL=https://api.openai.com
KLEIN_GROK_BASE_URL=https://grok.com

KLEIN_PROVIDER_GPT=mock
KLEIN_PROVIDER_GROK=mock

KLEIN_CORS_ORIGINS=http://localhost:17080,http://localhost:17088
