# Generated automatically by deploy/init-env.ps1 or deploy/init-env.sh when possible.
GPT2API_IMAGE=ghcr.io/alice-qwq77/gpt2api:latest

HTTP_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=gpt2api
MYSQL_USER=gpt2api
MYSQL_PASSWORD=change-me-db-password

GPT2API_APP_ENV=prod
GPT2API_APP_BASE_URL=http://localhost:8080

JWT_SECRET=change-me-to-a-random-32-char-secret
CRYPTO_AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

BACKUP_RETENTION=30
BACKUP_ALLOW_RESTORE=false

DNS_PRIMARY=8.8.8.8
DNS_FALLBACK=1.1.1.1
